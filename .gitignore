# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
.next/
out/

# expo — pin the ignore to the prebuild output directory under apps/mobile/,
# NOT every `ios/` or `android/` directory in the tree, otherwise local Expo
# native modules at `apps/mobile/modules/*/ios/` and their Kotlin siblings
# get wiped from the source tree.
.expo/
/apps/mobile/ios/
/apps/mobile/android/
*.jks
*.keystore

# production
build/

# testing
coverage/
playwright-report/
test-results/
apps/web/e2e/.auth/

# misc
.DS_Store
*.pem
Icon?

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# serwist (generated service worker)
**/public/sw.js
**/public/sw.js.map
**/public/serwist-worker-*

# other
.playwright-mcp
supabase/.temp/

# AI model cache — transformers.js writes to .cache/ when running in Node
# mode (e.g. server-side tests). Browser Gemma weights live in Cache Storage
# under `nivoca-gemma-cache` (per-origin), with an additional out-of-repo
# mirror at `~/develop/ai/` served by the dev-only `/models/[...path]` route.
# Neither path is inside the repo, so no extra entries needed — kept here in
# case anyone accidentally puts a `.cache/` next to the source tree.
.cache/

# seed data (bulk fixture files, not checked in)
apps/web/scripts/data/

# Vendored LiteRT-LM XCFramework (~205 MB total, with two 82 MB static
# binaries that exceed GitHub's 50 MB warning threshold). Each developer
# fetches it locally from the hung-yueh/react-native-litert-lm v0.3.6
# release before running `bunx expo run:ios`. The README inside the
# directory is intentionally tracked so newcomers know what's missing.
/apps/mobile/modules/nivoca-ai/ios/Frameworks/*
!/apps/mobile/modules/nivoca-ai/ios/Frameworks/README.md

# Claude Code scheduled-task lock (per-session runtime artefact)
.claude/scheduled_tasks.lock
